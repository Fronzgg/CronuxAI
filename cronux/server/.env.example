# Ollama (локальный запуск Qwen)
OLLAMA_URL=http://localhost:11434

# Или Together.ai API (pay-as-you-go)
TOGETHER_API_KEY=your_together_api_key_here

# Или DeepSeek API (для CronuxPro)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# SerpAPI для поиска (опционально)
SERP_API_KEY=your_serp_api_key_here

# Режим: "mock" | "ollama" | "together" | "deepseek"
AI_MODE=mock

PORT=3000
